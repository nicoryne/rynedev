---
const socials = [
  { text: 'GitHub', href: 'https://github.com/nicoryne' },
  { text: 'LinkedIn', href: 'https://www.linkedin.com/in/nicolo-ryne-porter-4418b4218/' },
  { text: 'Facebook', href: 'https://www.facebook.com/RYNE.DEV' },
  { text: 'Twitter / X', href: 'https://x.com/rynedevph' },
  { text: 'Email', href: 'mailto:contact@ryne.dev' }
];

const techStack = [
  'Next.js / React / Astro',
  'TypeScript / Java / SQL',
  'AWS / ServiceNow Cloud',
  'PostgreSQL / Supabase / NoSQL'
];
---

<footer class="py-12 md:py-16 bg-bg border-t border-border section-enter" id="contact">
  <div class="grid grid-cols-1 md:grid-cols-[1fr_1.5fr_1fr] gap-10 md:gap-12 mb-16 md:mb-20 container mx-auto px-4 md:px-8">
    <!-- Column 1: Socials -->
    <div>
      <div class="text-[0.65rem] tracking-[0.1em] uppercase mb-6 pb-2 border-b border-border-light font-mono text-text-muted">Socials & Contact</div>
      <ul class="flex flex-col gap-3">
        {socials.map((link) => (
          <li class="text-[0.85rem]">
            <a href={link.href} target="_blank" rel="noopener noreferrer" class="group inline-block link-hover">
              {link.text} <span class="inline-block text-[0.75rem] transition-transform duration-200 group-hover:translate-x-[2px] group-hover:-translate-y-[2px]">↗</span>
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Column 2: Location & Education -->
    <div>
      <div class="text-[0.65rem] tracking-[0.1em] uppercase mb-6 pb-2 border-b border-border-light font-mono text-text-muted">Location & Education</div>
      <div class="flex flex-col gap-5 text-[0.85rem]">
        <p class="mb-0 leading-[1.5]">
          <strong class="font-mono text-[0.65rem] uppercase tracking-[0.05em] text-text-muted block">Location</strong>
          Cebu City, Cebu, Philippines
        </p>
        <div class="mb-0 leading-[1.5]">
          <strong class="font-mono text-[0.65rem] uppercase tracking-[0.05em] text-text-muted block">Education</strong>
          <div class="mt-[0.4rem] flex flex-col gap-[0.2rem]">
            <div class="flex items-center gap-2 flex-wrap">
              <span>BS in Information Technology</span>
            </div>
            <div class="text-text-muted text-[0.8rem]">Cebu Institute of Technology — University</div>
            <div class="text-text-muted text-[0.7rem] font-mono tracking-wider text-accent border border-accent inline-block px-1.5 py-0.5 rounded w-max">CUM LAUDE</div>
            <div class="font-mono text-text-muted text-[0.7rem] mt-[0.1rem]">CLASS OF 2026</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Column 3: Tech Stack -->
    <div>
      <div class="text-[0.65rem] tracking-[0.1em] uppercase mb-6 pb-2 border-b border-border-light font-mono text-text-muted">Technologies & Services</div>
      <ul class="flex flex-col gap-3 font-mono">
        {techStack.map((tech) => (
          <li class="text-[0.75rem] text-text-muted">{tech}</li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Big Brand Closing -->
  <div class="border-t border-border pt-8 md:pt-12 container mx-auto px-4 md:px-8">
    <div class="font-serif text-[clamp(3.5rem,12vw,8.5rem)] font-bold leading-[0.85] tracking-[-0.05em] mb-6 md:mb-8 text-left">RYNE<span class="text-accent">.</span>DEV</div>
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center text-[0.65rem] text-text-muted tracking-[0.05em] flex-wrap gap-2 md:gap-4">
      <span class="font-mono">© 2026 NICOLO RYNE PORTER. ALL RIGHTS RESERVED.</span>
      <span class="font-mono">VOL. 01 — ISS. 1.0</span>
    </div>
  </div>
</footer>
